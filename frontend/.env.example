# ── KRONOS frontend environment ──────────────────────────────────────────────
#
# By DEFAULT you need NONE of these. The browser calls the same Vercel origin
# under /api/* and Next.js rewrites those requests to the KRONOS engine
# (see next.config.ts) — this sidesteps CORS entirely.
#
# Only set these to override that behaviour.

# Call the engine DIRECTLY from the browser instead of via the same-origin
# proxy. Requires the backend to allow-list this frontend's origin in CORS.
# Leave blank/unset to use the proxy (recommended).
# NEXT_PUBLIC_API_BASE_URL=https://usaihacks.onrender.com

# Where the rewrite proxy forwards /api/* (build-time only, see next.config.ts).
# Defaults to the deployed engine; override to point at a local/staging backend.
# KRONOS_API_ORIGIN=https://usaihacks.onrender.com
